{
  "name": "daily-hub",
  "version": "0.1.0",
  "private": true,
  "description": "Agenda pessoal centrada no dia — tarefas, metas, notas, compromissos e contatos, todos interligados.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "free-port": "lsof -ti tcp:3333 | xargs kill -9 2>/dev/null || true",
    "dev": "pnpm free-port && turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "pnpm --filter @daily-hub/db generate",
    "db:migrate": "pnpm --filter @daily-hub/db migrate",
    "db:studio": "pnpm --filter @daily-hub/db studio",
    "db:seed": "pnpm --filter @daily-hub/db seed",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@eslint/js": "^9.6.1",
    "eslint": "^9.6.1",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.8.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md}": "prettier --write"
  }
}
