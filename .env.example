# ---- Banco de dados (Postgres via docker-compose) ----
DATABASE_URL="postgresql://daily:daily@localhost:5432/daily_hub?schema=public"

# ---- API (NestJS) ----
# Em produção, a PaaS (Railway) injeta PORT e a API a usa no lugar de API_PORT.
API_PORT=3333
API_CORS_ORIGIN="http://localhost:5173"
# Segredo de assinatura dos JWT (troque por um valor aleatório forte).
API_JWT_SECRET="dev-secret-change-me"
# Validade do token (formato do `jsonwebtoken`, ex.: 7d, 12h).
API_JWT_EXPIRES_IN="7d"

# ---- Storage (S3-compatível / MinIO) ----
STORAGE_ENDPOINT="http://localhost:9000"
STORAGE_BUCKET="daily-hub-attachments"
STORAGE_ACCESS_KEY="minioadmin"
STORAGE_SECRET_KEY="minioadmin"
STORAGE_REGION="us-east-1"
# Validade das URLs assinadas (segundos): 1h = 3600
STORAGE_PRESIGNED_EXPIRES_IN=3600

# ---- Web (Vite) ----
# Variáveis do front precisam do prefixo VITE_
VITE_API_URL="http://localhost:3333"
